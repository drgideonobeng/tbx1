// =============================================================================
// phase3a/nextflow.config — Cross-sample integration pipeline
// Project : Tbx1
// Author  : Gideon Obeng
// Version : 1.0.0
// =============================================================================

manifest {
    name            = 'tbx1-scRNAseq-phase3a'
    author          = 'Gideon Obeng'
    description     = 'scVI integration of Tbx1 WT vs KO across E8.5 and E9.5'
    version         = '1.0.0'
    nextflowVersion = '>=26.04.0'
}

// =============================================================================
// 1. PARAMETERS
// =============================================================================

params {

    // -------------------------------------------------------------------------
    // Input — per-sample filtered RDS paths (from Phase 1 step 04)
    // -------------------------------------------------------------------------
    wt_e85_rds = ""
    wt_e95_rds = ""
    ko_e85_rds = ""
    ko_e95_rds = ""

    // -------------------------------------------------------------------------
    // Project infrastructure
    // -------------------------------------------------------------------------
    project_name = "Tbx1_ctrl_vs_ko"
    resultsdir   = "${projectDir}/../results/integrated"
    cleanup_work = false

    // -------------------------------------------------------------------------
    // Integration parameters
    // -------------------------------------------------------------------------
    n_hvgs      = 3000  // Highly variable genes selected per sample before integration
    scvi_dims   = 30    // Latent dimensions for scVI model
    cluster_res = 0.4   // Louvain resolution on integrated embedding (validate with clustree)
}

// =============================================================================
// 2. PROCESS DEFAULTS
// =============================================================================

process {
    debug = true

    beforeScript = 'export R_MAX_VSIZE=32Gb'

    cpus   = 2
    memory = '8 GB'
    time   = '2 h'

    errorStrategy = 'terminate'
    maxRetries    = 2
}

// =============================================================================
// 3. EXECUTION PROFILES
// =============================================================================

profiles {

    standard {
        process.executor = 'local'
    }

    conda {
        conda.enabled  = true
        conda.cacheDir = "${System.getProperty('user.home')}/.conda/nextflow-envs"
        process {
            withName: 'PREP_NORMALIZE|CLUSTER_INTEGRATED|RUN_CLUSTREE|FIND_MARKERS' {
                conda = "${projectDir}/../scrna.yml"
            }
            withName: 'INTEGRATE_SCVI' {
                conda = "${projectDir}/env.yml"
            }
        }
    }

    apple_silicon {
        process {
            withName: 'PREP_NORMALIZE' {
                cpus     = 4
                memory   = { 16.GB * task.attempt }
                time     = '2 h'
                maxForks = 2   // Run at most 2 samples in parallel (memory-bound)
            }
            withName: 'INTEGRATE_SCVI' {
                cpus   = 4
                memory = '48 GB'
                time   = '4 h'
            }
        }
    }

    low_mem {
        process {
            withName: 'PREP_NORMALIZE' {
                cpus     = 2
                memory   = { 8.GB * task.attempt }
                time     = '4 h'
                maxForks = 1
            }
            withName: 'INTEGRATE_SCVI' {
                cpus   = 2
                memory = { 12.GB * task.attempt }
                time   = '8 h'
            }
        }
    }

    hpc {
        process.executor = 'slurm'
        process {
            withName: 'PREP_NORMALIZE' {
                cpus   = 8
                memory = { 32.GB * task.attempt }
                time   = '2 h'
            }
            withName: 'INTEGRATE_SCVI' {
                cpus   = 16
                memory = { 64.GB * task.attempt }
                time   = '6 h'
                queue  = 'highmem'
            }
        }
    }
}

// =============================================================================
// 4. PIPELINE OBSERVABILITY
// =============================================================================

timeline {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/trace.txt"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/flowchart.html"
    overwrite = true
}

// =============================================================================
// 5. WORK DIRECTORY CLEANUP
// =============================================================================

cleanup = params.cleanup_work

// =============================================================================
// phase1/nextflow.config — Single-Cell RNA-seq Pipeline
// Project : Tbx1
// Author  : Gideon Obeng
// Version : 1.0.0
// =============================================================================

manifest {
    name            = 'tbx1-scRNAseq'
    author          = 'Gideon Obeng'
    description     = 'Single-cell RNA-seq pipeline for Tbx1-cardiopharyngeal lineage'
    version         = '1.0.0'
    nextflowVersion = '>=26.04.0'
}

// =============================================================================
// 1. PARAMETERS
// =============================================================================

params {

    // -------------------------------------------------------------------------
    // Input Data
    // -------------------------------------------------------------------------
    barcodes_url = ""
    features_url = ""
    matrix_url   = ""

    // -------------------------------------------------------------------------
    // Project Infrastructure
    // -------------------------------------------------------------------------
    project_name = "Tbx1"
    datadir      = "${projectDir}/../data/e85"
    resultsdir   = "${projectDir}/../results/e85"

    // Set to 'true' to delete work/ after a successful run (saves disk space)
    // Set to 'false' to retain work/ for debugging and -resume (rm -rf to delete manually)
    cleanup_work = false

    // -------------------------------------------------------------------------
    // Biological Parameters
    // -------------------------------------------------------------------------
    species    = "mouse"
    mt_pattern = "^mt-"        // Mouse mitochondrial prefix (human: "^MT-")

    // -------------------------------------------------------------------------
    // QC Thresholds
    // -------------------------------------------------------------------------
    min_cells      = 3      // Minimum cells a gene must appear in
    min_features   = 200    // Minimum genes per cell (removes empty droplets)
    min_genes      = 200    // Lower bound for nFeature_RNA filter
    max_genes      = 6000   // Upper bound for nFeature_RNA filter (removes doublets)
    max_mt_percent = 5      // Maximum mitochondrial % (removes dying cells)

    // -------------------------------------------------------------------------
    // Dimensionality Reduction & Clustering
    // -------------------------------------------------------------------------
    pca_dims    = 20    // Number of PCs for UMAP and clustering (validate with elbow plot)
    cluster_res = 0.4   // Louvain resolution (higher = more clusters; validate with clustree)
}

// =============================================================================
// 2. PROCESS DEFAULTS
// Machine-agnostic baseline. Resource overrides for heavy processes live in
// the execution profiles (apple_silicon, low_mem, hpc).
// =============================================================================

process {

    // Print process stdout/stderr to terminal (set false for clean production runs)
    debug = true

    // Raise R's memory ceiling globally (important for Apple Silicon / large objects)
    beforeScript = 'export R_MAX_VSIZE=32Gb'

    // Default resources for lightweight steps
    cpus   = 2
    memory = '8 GB'
    time   = '1 h'

    // Fail loudly on error rather than silently terminating
    errorStrategy = 'terminate'
    maxRetries    = 2
}

// =============================================================================
// 3. EXECUTION PROFILES
// =============================================================================

profiles {

    // Default: uses your active terminal environment
    standard {
        process.executor = 'local'
    }

    // Recommended for reproducibility — uses env.yml
    conda {
        process.conda  = "${projectDir}/../env.yml"
        conda.enabled  = true
        conda.cacheDir = "${System.getProperty('user.home')}/.conda/nextflow-envs"
    }

    // Apple Silicon (M-series Mac, 32 GB+ unified memory)
    apple_silicon {
        process {
            withName: 'NORMALIZE_DATA' {
                cpus   = 8
                memory = { 32.GB * task.attempt }   // Scales up on retry
                time   = '2 h'
            }
        }
    }

    // Standard laptop/desktop (8–16 GB RAM)
    low_mem {
        process {
            withName: 'NORMALIZE_DATA' {
                cpus   = 4
                memory = { 8.GB * task.attempt }
                time   = '4 h'
            }
        }
    }

    // HPC cluster (SLURM)
    hpc {
        process.executor = 'slurm'
        process {
            withName: 'NORMALIZE_DATA' {
                cpus   = 16
                memory = { 64.GB * task.attempt }
                time   = '4 h'
                queue  = 'highmem'
            }
        }
    }

    // Containerized run via Seurat Docker image
    docker {
        docker.enabled    = true
        process.container = 'satijalab/seurat:latest'
    }
}

// =============================================================================
// 4. PIPELINE OBSERVABILITY
// Always generated to results/pipeline_info/ — no command-line flags needed.
// =============================================================================

timeline {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/trace.txt"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/flowchart.html"
    overwrite = true
}

// =============================================================================
// 5. WORK DIRECTORY CLEANUP
// =============================================================================

cleanup = params.cleanup_work

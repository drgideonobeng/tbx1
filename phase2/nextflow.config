// =============================================================================
// phase2/nextflow.config — Biological Insight Pipeline
// Project : Tbx1
// Author  : Gideon Obeng
// Version : 1.0.0
// =============================================================================

manifest {
    name            = 'tbx1-scRNAseq-phase2'
    author          = 'Gideon Obeng'
    description     = 'Phase 2: marker discovery and annotation for Tbx1-cardiopharyngeal lineage'
    version         = '1.0.0'
    nextflowVersion = '>=26.04.0'
}

// =============================================================================
// 1. PARAMETERS
// =============================================================================

params {

    // Required: path to 06_seurat_clustered.rds produced by Phase 1
    clustered_rds = null

    // -------------------------------------------------------------------------
    // Project Infrastructure (must match the Phase 1 timepoint run)
    // -------------------------------------------------------------------------
    project_name = "Tbx1"
    resultsdir   = "${projectDir}/../results/e85"
    cleanup_work = false

    // -------------------------------------------------------------------------
    // Biological Parameters
    // -------------------------------------------------------------------------
    marker_genes   = "Tbx1,Fgf8,Isl1,Nkx2-5,Pax9,Six1"
    cluster_labels = "${projectDir}/../config/cluster_labels/e85.csv"
}

// =============================================================================
// 2. PROCESS DEFAULTS
// =============================================================================

process {
    debug         = true
    beforeScript  = 'export R_MAX_VSIZE=32Gb'
    cpus          = 2
    memory        = '8 GB'
    time          = '1 h'
    errorStrategy = 'terminate'
    maxRetries    = 2
}

// =============================================================================
// 3. EXECUTION PROFILES
// =============================================================================

profiles {

    standard {
        process.executor = 'local'
    }

    conda {
        process.conda  = "${projectDir}/../scrna.yml"
        conda.enabled  = true
        conda.cacheDir = "${System.getProperty('user.home')}/.conda/nextflow-envs"
    }

    apple_silicon {
        process {
            withName: 'FIND_MARKERS' {
                cpus   = 8
                memory = { 32.GB * task.attempt }
                time   = '2 h'
            }
        }
    }

    low_mem {
        process {
            withName: 'FIND_MARKERS' {
                cpus   = 4
                memory = { 8.GB * task.attempt }
                time   = '4 h'
            }
        }
    }

    hpc {
        process.executor = 'slurm'
        process {
            withName: 'FIND_MARKERS' {
                cpus   = 16
                memory = { 64.GB * task.attempt }
                time   = '4 h'
                queue  = 'highmem'
            }
        }
    }

    docker {
        docker.enabled    = true
        process.container = 'satijalab/seurat:latest'
    }
}

// =============================================================================
// 4. PIPELINE OBSERVABILITY
// Prefixed "phase2_" so Phase 1 and Phase 2 reports coexist in pipeline_info/
// =============================================================================

timeline {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/phase2_timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/phase2_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/phase2_trace.txt"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/phase2_flowchart.html"
    overwrite = true
}

// =============================================================================
// 5. WORK DIRECTORY CLEANUP
// =============================================================================

cleanup = params.cleanup_work

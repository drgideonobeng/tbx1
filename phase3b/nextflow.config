// =============================================================================
// phase3b/nextflow.config — Annotation, DE & enrichment pipeline
// Project : Tbx1
// Author  : Gideon Obeng
// Version : 1.0.0
// =============================================================================

manifest {
    name            = 'tbx1-scRNAseq-phase3b'
    author          = 'Gideon Obeng'
    description     = 'Annotation, differential expression and GO enrichment for Tbx1 WT vs KO'
    version         = '1.0.0'
    nextflowVersion = '>=26.04.0'
}

// =============================================================================
// 1. PARAMETERS
// =============================================================================

params {
    clustered_rds  = ""
    cluster_labels = ""
    min_cells      = 10
    lfc_threshold  = 0.25
    padj_threshold = 0.05
    go_padj        = 0.05
    go_min_genes   = 5
    resultsdir     = "./results_phase3b"
    cleanup_work   = false
}

// =============================================================================
// 2. PROCESS DEFAULTS
// Machine-agnostic baseline. Resource overrides for heavy processes live in
// the execution profiles (apple_silicon, low_mem, hpc).
// =============================================================================

process {
    debug         = true
    beforeScript  = 'export R_MAX_VSIZE=32Gb'
    cpus          = 2
    memory        = '8 GB'
    time          = '1 h'
    errorStrategy = 'terminate'
    maxRetries    = 2

    withName: 'DIFFERENTIAL_EXPRESSION' {
        memory = '16 GB'
        time   = '2 h'
    }
}

// =============================================================================
// 3. EXECUTION PROFILES
// =============================================================================

profiles {

    standard {
        process.executor = 'local'
    }

    conda {
        process.conda  = "${projectDir}/../scrna.yml"
        conda.enabled  = true
        conda.cacheDir = "${System.getProperty('user.home')}/.conda/nextflow-envs"
    }

    apple_silicon {
        process {
            withName: 'DIFFERENTIAL_EXPRESSION' {
                cpus   = 4
                memory = { 16.GB * task.attempt }
                time   = '2 h'
            }
        }
    }

    low_mem {
        process {
            withName: 'DIFFERENTIAL_EXPRESSION' {
                cpus   = 2
                memory = { 8.GB * task.attempt }
                time   = '4 h'
            }
        }
    }

    hpc {
        process.executor = 'slurm'
        process {
            withName: 'DIFFERENTIAL_EXPRESSION' {
                cpus   = 8
                memory = { 32.GB * task.attempt }
                time   = '2 h'
                queue  = 'highmem'
            }
        }
    }
}

// =============================================================================
// 4. PIPELINE OBSERVABILITY
// =============================================================================

timeline {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/trace.txt"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.resultsdir}/pipeline_info/flowchart.html"
    overwrite = true
}

// =============================================================================
// 5. WORK DIRECTORY CLEANUP
// =============================================================================

cleanup = params.cleanup_work
